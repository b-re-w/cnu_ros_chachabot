<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="cnuchacha" params="parent prefix *origin">
    <!-- Constants for Chacha & Nupjuki dimensions -->
    <xacro:property name="mass" value="1.0" />
    <xacro:property name="body_w" value="0.3" /> <!-- y -->
    <xacro:property name="body_d" value="0.2" /> <!-- x -->
    <xacro:property name="body_h" value="0.4" /> <!-- z -->
    <xacro:property name="leg_r" value="0.06" />
    <xacro:property name="leg_l" value="0.3" />
    <xacro:property name="arm_r" value="0.05" />
    <xacro:property name="arm_l" value="0.35" />
    <xacro:property name="head_r" value="0.2" />

    <joint name="${prefix}base_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}"/>
      <child link="${prefix}base_link" />
    </joint>

    <!-- Base Link (Torso / Chacha's Navy Body) -->
    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 ${body_h/2 + leg_l}" rpy="0 0 0"/>
        <geometry><box size="${body_d} ${body_w} ${body_h}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${body_h/2 + leg_l}" rpy="0 0 0"/>
        <geometry><box size="${body_d} ${body_w} ${body_h}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${body_h/2 + leg_l}" rpy="0 0 0"/>
        <mass value="${mass * 5}"/>
        <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
      </inertial>
    </link>

    <!-- Hat Brim -->
    <joint name="${prefix}hat_brim_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}hat_brim_link"/>
      <origin xyz="0 0 ${leg_l + body_h + head_r}" rpy="0 0 0"/>
    </joint>
    <link name="${prefix}hat_brim_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><box size="0.35 0.25 0.1"/></geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><box size="0.35 0.25 0.1"/></geometry>
      </collision>
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>

    <!-- Chacha Head -->
    <joint name="${prefix}head_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}head_link"/>
      <origin xyz="0 0 ${leg_l + body_h + 0.05}" rpy="0 0 0"/>
    </joint>
    <link name="${prefix}head_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="${head_r}"/></geometry>
        <material name="white"/>
      </visual>
      <visual> <!-- Snout -->
        <origin xyz="${head_r*0.7} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry><cylinder radius="0.12" length="0.4"/></geometry>
        <material name="beige"/>
      </visual>
      <visual>
        <origin xyz="${head_r*0.7 + 0.2} 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="0.12"/></geometry>
        <material name="beige"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="${head_r}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${mass}"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <!-- Legs -->
    <joint name="${prefix}left_leg_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}left_leg"/>
      <origin xyz="0 ${body_w/4} ${leg_l}" rpy="0 0 0"/>
    </joint>
    <link name="${prefix}left_leg">
      <visual>
        <origin xyz="0 0 ${-leg_l/2}" rpy="0 0 0"/>
        <geometry><cylinder radius="${leg_r}" length="${leg_l}"/></geometry>
        <material name="white"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-leg_l/2}" rpy="0 0 0"/>
        <geometry><cylinder radius="${leg_r}" length="${leg_l}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-leg_l/2}" rpy="0 0 0"/>
        <mass value="${mass}"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <joint name="${prefix}right_leg_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}right_leg"/>
      <origin xyz="0 ${-body_w/4} ${leg_l}" rpy="0 0 0"/>
    </joint>
    <link name="${prefix}right_leg">
      <visual>
        <origin xyz="0 0 ${-leg_l/2}" rpy="0 0 0"/>
        <geometry><cylinder radius="${leg_r}" length="${leg_l}"/></geometry>
        <material name="white"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-leg_l/2}" rpy="0 0 0"/>
        <geometry><cylinder radius="${leg_r}" length="${leg_l}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-leg_l/2}" rpy="0 0 0"/>
        <mass value="${mass}"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <!-- Left Foot -->
    <joint name="${prefix}left_foot_joint" type="fixed">
      <parent link="${prefix}left_leg"/>
      <child link="${prefix}left_foot"/>
      <origin xyz="0 0 ${-leg_l}" rpy="0 0 0"/>
    </joint>
    <link name="${prefix}left_foot">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="0.08"/></geometry>
        <material name="blue"/>
      </visual>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>

    <!-- Right Foot -->
    <joint name="${prefix}right_foot_joint" type="fixed">
      <parent link="${prefix}right_leg"/>
      <child link="${prefix}right_foot"/>
      <origin xyz="0 0 ${-leg_l}" rpy="0 0 0"/>
    </joint>
    <link name="${prefix}right_foot">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="0.08"/></geometry>
        <material name="blue"/>
      </visual>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>

    <!-- Arms (joint1 and joint2 for backward compatibility with controllers) -->
    <!-- Left Arm -->
    <joint name="${prefix}joint1" type="revolute">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}left_arm"/>
      <origin xyz="0 ${body_w/2 + arm_r} ${leg_l + body_h - arm_r*2}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.7"/>
      <limit effort="100" velocity="1.0" lower="-1.57" upper="1.57"/>
    </joint>
    <link name="${prefix}left_arm">
      <visual>
        <origin xyz="0 0 ${-arm_l/2}" rpy="0 0 0"/>
        <geometry><cylinder radius="${arm_r}" length="${arm_l}"/></geometry>
        <material name="white"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-arm_l/2}" rpy="0 0 0"/>
        <geometry><cylinder radius="${arm_r}" length="${arm_l}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-arm_l/2}" rpy="0 0 0"/>
        <mass value="${mass}"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <!-- Right Arm -->
    <joint name="${prefix}joint2" type="revolute">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}right_arm"/>
      <origin xyz="0 ${-body_w/2 - arm_r} ${leg_l + body_h - arm_r*2}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.7"/>
      <limit effort="100" velocity="1.0" lower="-1.57" upper="1.57"/>
    </joint>
    <link name="${prefix}right_arm">
      <visual>
        <origin xyz="0 0 ${-arm_l/2}" rpy="0 0 0"/>
        <geometry><cylinder radius="${arm_r}" length="${arm_l}"/></geometry>
        <material name="white"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-arm_l/2}" rpy="0 0 0"/>
        <geometry><cylinder radius="${arm_r}" length="${arm_l}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-arm_l/2}" rpy="0 0 0"/>
        <mass value="${mass}"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <!-- Left Hand -->
    <joint name="${prefix}left_hand_joint" type="fixed">
      <parent link="${prefix}left_arm"/>
      <child link="${prefix}left_hand"/>
      <origin xyz="0 0 ${-arm_l}" rpy="0 0 0"/>
    </joint>
    <link name="${prefix}left_hand">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="0.07"/></geometry>
        <material name="white"/>
      </visual>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>

    <!-- Right Hand -->
    <joint name="${prefix}right_hand_joint" type="fixed">
      <parent link="${prefix}right_arm"/>
      <child link="${prefix}right_hand"/>
      <origin xyz="0 0 ${-arm_l}" rpy="0 0 0"/>
    </joint>
    <link name="${prefix}right_hand">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="0.07"/></geometry>
        <material name="white"/>
      </visual>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>

    <!-- Nupjuki (KAIST Mascot on Hat) -->
    <joint name="${prefix}nupjuki_joint" type="revolute">
      <parent link="${prefix}head_link"/>
      <child link="${prefix}nupjuki_link"/>
      <origin xyz="0 0 ${head_r}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="0.7"/>
      <limit effort="100" velocity="1.0" lower="-3.14" upper="3.14"/>
    </joint>
    <link name="${prefix}nupjuki_link">
      <!-- Nupjuki Body -->
      <visual>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry><cylinder radius="0.06" length="0.15"/></geometry>
        <material name="cyan"/>
      </visual>
      <!-- Nupjuki Flat Head -->
      <visual>
        <origin xyz="0 0 0.15" rpy="0 0 0"/>
        <geometry><box size="0.15 0.6 0.075"/></geometry>
        <material name="blue"/>
      </visual>
      <!-- Left Eye -->
      <visual>
        <origin xyz="0.075 0.12 0.15" rpy="0 ${pi/2} 0"/>
        <geometry><cylinder radius="0.03" length="0.015"/></geometry>
        <material name="black"/>
      </visual>
      <!-- Right Eye -->
      <visual>
        <origin xyz="0.075 -0.12 0.15" rpy="0 ${pi/2} 0"/>
        <geometry><cylinder radius="0.03" length="0.015"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.15" rpy="0 0 0"/>
        <geometry><box size="0.15 0.6 0.075"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.15" rpy="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>

  </xacro:macro>
</robot>
